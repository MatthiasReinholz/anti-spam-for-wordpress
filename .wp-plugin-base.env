FOUNDATION_REPOSITORY=MatthiasReinholz/wp-plugin-base
FOUNDATION_VERSION=v1.7.3
PLUGIN_NAME="Anti Spam for WordPress"
PLUGIN_SLUG=anti-spam-for-wordpress
MAIN_PLUGIN_FILE=anti-spam-for-wordpress.php
README_FILE=readme.txt
ZIP_FILE=anti-spam-for-wordpress-plugin.zip
PHP_VERSION=8.0
NODE_VERSION=20
PRODUCTION_ENVIRONMENT=production
VERSION_CONSTANT_NAME=ASFW_VERSION
POT_FILE=languages/anti-spam-for-wordpress.pot
POT_PROJECT_NAME="Anti Spam for WordPress"
WORDPRESS_ORG_SLUG=anti-spam-for-wordpress
WORDPRESS_READINESS_ENABLED=true
WORDPRESS_QUALITY_PACK_ENABLED=false
WORDPRESS_SECURITY_PACK_ENABLED=false
PHP_RUNTIME_MATRIX=8.1,8.2,8.3
PHP_RUNTIME_MATRIX_MODE=strict
REST_OPERATIONS_PACK_ENABLED=true
REST_API_NAMESPACE=anti-spam-for-wordpress/v1
ADMIN_UI_PACK_ENABLED=true
ADMIN_UI_STARTER=basic
BUILD_SCRIPT=.wp-plugin-base-admin-ui/build.sh

WP_PLUGIN_BASE_PLUGIN_CHECK_CHECKS=plugin_header_fields,plugin_readme
WP_PLUGIN_BASE_PLUGIN_CHECK_STRICT_WARNINGS=false
WP_PLUGIN_BASE_PLUGIN_CHECK_ERROR_SEVERITY=999
